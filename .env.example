APP_NAME=TukTak AI Service
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=true

MAIN_BACKEND_URL=http://localhost:8000

CHROMA_PATH=./data/chroma
CHROMA_REPAIR_CASE_COLLECTION=repair_cases
CHROMA_RISK_DOCUMENT_COLLECTION=risk_documents
CHROMA_REPAIR_MANUAL_COLLECTION=repair_manuals
