APP_NAME=TukTak AI Service
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=true

MAIN_BACKEND_URL=http://localhost:8000

CHROMA_PATH=./data/chroma
CHROMA_REPAIR_CASE_COLLECTION=repair_cases
CHROMA_RISK_DOCUMENT_COLLECTION=risk_documents_ko_sroberta_v2
CHROMA_REPAIR_MANUAL_COLLECTION=repair_manuals
CHROMA_PRICE_REFERENCE_COLLECTION=price_references
PRICE_REFERENCE_FILE_PATH=data/price_reference/base_price_table.csv

EMBEDDING_MODEL_NAME=BAAI/bge-m3
AI_TORCH_DEVICE=auto

NLP_STRUCTURING_MODEL_NAME=KLUE-RoBERTa-base
NLP_STRUCTURING_BASE_MODEL_NAME=klue/roberta-base
NLP_STRUCTURING_MODEL_PATH=data/models/KLUE-RoBERTa-base
NLP_STRUCTURING_HF_REPO_ID=
NLP_STRUCTURING_HF_REVISION=
NLP_STRUCTURING_HF_TOKEN=
NLP_STRUCTURING_AUTO_DOWNLOAD=true
NLP_STRUCTURING_MAX_LENGTH=192
NLP_STRUCTURING_MISSING_THRESHOLD=0.5

OPENAI_API_KEY=
OPENAI_API_KEY_AI_ESTIMATE=
OPENAI_API_KEY_AI_RISKREPORT=
OPENAI_ESTIMATE_MODEL=gpt-5-mini
OPENAI_ESTIMATE_TIMEOUT_SECONDS=60
OPENAI_RISK_REPORT_MODEL=gpt-5-mini
OPENAI_RISK_REPORT_TIMEOUT_SECONDS=60

RISK_EMBEDDING_MODEL_NAME=jhgan/ko-sroberta-multitask
RISK_RAG_METADATA_PATH=data/rag_documents/rag_metadata_unified.xlsx
RISK_RAG_TOP_K=3
RISK_RAG_PRICE_THRESHOLD=0.30
RISK_RAG_EXTRA_COST_THRESHOLD=0.55
RISK_RAG_SAFETY_THRESHOLD=0.60
RISK_RAG_CONTRACT_THRESHOLD=0.60
RISK_RAG_FIELD_THRESHOLD=0.65

AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=
